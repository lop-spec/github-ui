{
  "owner": "lop-spec",
  "repo": "codex_webui_sync",
  "branch": "main",
  "runtimeRoot": "codex-webui-runtime",
  "intervalMs": 30000,
  "maxApplyPerRun": 200,
  "protectedPaths": [
    "Codex-webui-ts/history.json",
    "codex/rules/default.rules",
    "codex/skills/.system/**",
    ".codex/**",
    ".agents/**",
    "logs/**",
    "outputs/**",
    "**/logs/**",
    "**/outputs/**",
    "**/history/**",
    "**/sessions/**",
    "**/auth/**",
    "**/.system/**",
    "**/config.toml"
  ],
  "protectedTerms": [],
  "protectedRuleTerms": [],
  "verifyAfterApply": true,
  "verifyCommands": [
    {
      "name": "github-sync-focused-tests",
      "command": "node",
      "args": [
        "--test",
        "tests/github-sync.test.mjs",
        "tests/github-pull.test.mjs"
      ]
    }
  ]
}
