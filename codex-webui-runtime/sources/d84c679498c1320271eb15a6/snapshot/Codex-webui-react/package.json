{
  "name": "codex-webui-react",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.server.json && vite build",
    "check": "tsc -p tsconfig.server.json --noEmit && vite build",
    "parity:check": "node ../scripts/parity-check.mjs",
    "parity:check:full": "node ../scripts/parity-check.mjs --full",
    "parity:watch": "node ../scripts/parity-watch.mjs",
    "parity:watch:full": "node ../scripts/parity-watch.mjs --full",
    "serve": "node dist/server.js",
    "public": "npm run build && node dist/public-tunnel.js",
    "dev": "vite --host 127.0.0.1 --port 5175",
    "start": "npm run build && npm run serve",
    "test": "node --test --test-concurrency=1 tests/*.test.js"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "vite": "^7.3.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
